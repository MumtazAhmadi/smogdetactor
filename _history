nds\n    air = read_air()\n    if air >= MODERATE_THRESHOLD:\n        # Passive alert if air gets bad\n        show_polluted()\n        vibrate()\n        sleep(2000)\n\n    sleep(200)def on_forever():\n    pass\nbasic.forever(on_forever)\n"}]}],"snapshots":[{"timestamp":1776896534742,"editorVersion":"8.0.21","text":{"main.blocks":"<xml xmlns=\"http://www.w3.org/1999/xhtml\">\n  <block type=\"pxt-on-start\"></block>\n  <block type=\"device_forever\"></block>\n</xml>","main.ts":"\n","README.md":"","pxt.json":"{\n    \"name\": \"SmogDetactor\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"additionalFilePaths\": []\n}\n"}}],"shares":[],"lastSaveTime":1776896771376}